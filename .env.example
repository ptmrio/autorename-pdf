# AutoRename-PDF — Test Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.

# OpenAI API key (for live integration tests)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic API key (for live integration tests)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Ollama model (for local AI tests, default: qwen3:4b)
OLLAMA_MODEL=qwen3:4b
