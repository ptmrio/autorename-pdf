{
  "permissions": {
    "allow": [
      "Bash(python*)",
      "Bash(python build.py)",
      "Bash(pip install*)",
      "Bash(pip list*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git rm --cached*)",
      "Bash(python -c*)",
